  "steps": [
    {
      "id": 1,
      "type": "edge",
      "name": "Run Passive Analysis Mode",
      "from": "victim_endpoint_set",
      "to": "operator_node",
      "icon": "IconSearch",
      "cli": "sudo python3 Responder.py -I eth0 -A -v",
      "description": "Observe ambient protocol and authentication behavior without active poisoning.",
