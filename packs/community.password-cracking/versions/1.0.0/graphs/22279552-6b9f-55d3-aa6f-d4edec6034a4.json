  "steps": [
    {
      "id": 1,
      "type": "edge",
      "name": "Configure Proxy Routing Variables",
      "from": "operator_node",
      "to": "proxy_layer",
      "icon": "IconProcess",
      "cli": "HYDRA_PROXY=connect://proxy.anonymizer.com:8000",
      "description": "Define runtime proxy transport settings used by Hydra modules.",
      "mitre": {
        "id": "T1090.002",
        "tactic": "Command and Control",
        "technique": "External Proxy"
      }
    },
    {
      "id": 2,
      "type": "edge",
      "name": "Load Credential Candidates",
      "from": "candidate_sources",
      "to": "hydra_engine",
      "icon": "IconData",
      "cli": "hydra -L users.txt -P pass.txt ssh://target",
      "description": "Supply username/password candidates to the attack engine prior to routed authentication testing.",
      "mitre": {
        "id": "T1110.001",
        "tactic": "Credential Access",
        "technique": "Password Guessing"
      }
    },
    {
      "id": 3,
      "type": "edge",
      "name": "Enable Proxy Pool Rotation",
      "from": "proxy_pool",
      "to": "proxy_layer",
      "icon": "IconNetwork",
      "cli": "HYDRA_PROXY_HTTP='proxylist.txt' hydra -L users.txt -P pass.txt http-post-form://target",
      "description": "Optionally rotate transport routes through a proxy list for campaign resilience.",
      "mitre": {
        "id": "T1090.002",
        "tactic": "Command and Control",
        "technique": "External Proxy"
      }
    },
    {
      "id": 4,
      "type": "edge",
      "name": "Forward Attempts to Proxy",
      "from": "hydra_engine",
      "to": "proxy_layer",
      "icon": "IconSocks",
      "cli": "HYDRA_PROXY=socks4://auth:pw@127.0.0.1:1080 hydra -L users.txt -P pass.txt rdp://target",
      "description": "Hydra sends authentication attempts through configured proxy transport.",
      "mitre": {
        "id": "T1090.002",
        "tactic": "Command and Control",
        "technique": "External Proxy"
      }
    },
    {
      "id": 5,
      "type": "edge",
      "name": "Execute Remote Password Guessing",
      "from": "proxy_layer",
      "to": "target_auth_service",
      "icon": "IconExploit",
      "description": "Proxy-routed authentication attempts reach the target protocol endpoint.",
      "mitre": {
        "id": "T1110.001",
        "tactic": "Credential Access",
        "technique": "Password Guessing"
      }
    },
    {
      "id": 6,
      "type": "edge",
      "name": "Collect Authentication Outcomes",
      "from": "target_auth_service",
      "to": "auth_result_stream",
      "icon": "IconCredential",
      "description": "Success and failure responses are returned and parsed by module logic.",
      "mitre": {
        "id": "T1110.001",
        "tactic": "Credential Access",
        "technique": "Password Guessing"
      }
    },
    {
      "id": 7,
      "type": "edge",
      "name": "Extract Valid Credentials",
      "from": "auth_result_stream",
      "to": "discovered_credentials",
      "icon": "IconStolenCredential",
      "description": "Successful responses are promoted into validated credential findings.",
      "mitre": {
        "id": "T1078",
        "tactic": "Initial Access",
        "technique": "Valid Accounts"
      }
    },
    {
      "id": 8,
      "type": "edge",
      "name": "Return Results to Operator",
      "from": "discovered_credentials",
      "to": "operator_node",
      "icon": "IconCheck",
      "description": "Validated credentials are returned to the operator for controlled follow-on testing."
    }
  ],
