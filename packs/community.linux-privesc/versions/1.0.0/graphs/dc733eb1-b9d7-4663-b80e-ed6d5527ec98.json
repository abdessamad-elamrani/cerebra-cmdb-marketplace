      },
      "type": "edge",
      "from": "suid_payload",
      "to": "nfs_export",
      "description": "NFS propagates this as UID 0 due to no_root_squash, saving it to disk with root ownership intact"
    },
    {
      "id": 4,
      "name": "Trigger Execution",
      "mitre": {
