  "steps": [
    {
      "id": 1,
      "title": "Identify Missing DLL via Procmon",
      "description": "Monitor File APIs for privileged processes returning 'NAME NOT FOUND' for required .dll dependencies.",
      "command": "ProcessMonitor.exe /BackingFile \"procmon.pml\"",
      "mitre": "T1082",
      "status": "success",
      "impact": "Identified vulnerable process blindly requesting wlbsctrl.dll from the PATH.",
      "visibilityChanges": {
        "showNodes": [
          "procmon"
        ],
        "showEdges": [
          "e_procmon_monitor"
        ]
      },
      "newEdges": [
        {
          "id": "e_procmon_monitor",
          "source": "attacker_machine",
          "target": "procmon",
          "label": "Analyze ETW",
          "type": "Reconnaissance"
        },
        {
          "id": "e_procmon_vuln",
          "source": "procmon",
          "target": "vuln_process",
          "label": "Identify Leak",
          "type": "Reconnaissance"
        }
      ]
    },
    {
      "id": 2,
      "title": "Check PATH Directory Permissions",
      "description": "Iterate over every directory in the SYSTEM PATH variable and identify ones writable by non-admin users.",
      "command": "icacls \"C:\\\\Vulnerable\\\\Path\"",
      "mitre": "T1083",
      "status": "success",
      "impact": "Located a writable folder early in the PATH hierarchy.",
      "visibilityChanges": {
        "showNodes": [],
        "showEdges": [
          "e_check_path"
        ]
      },
      "newEdges": [
        {
          "id": "e_check_path",
          "source": "attacker_machine",
          "target": "env_path",
          "label": "Check ACLs",
          "type": "Reconnaissance"
        }
      ]
    },
    {
      "id": 3,
      "title": "Compile & Drop Malicious DLL",
      "description": "Compile a C payload wrapping command execution inside DllMain, match the exact filename of the missing library, and drop it in the writable PATH dir.",
      "command": "x86_64-w64-mingw32-gcc payload.c -shared -o MissingDLL.dll && copy MissingDLL.dll \"C:\\\\Vulnerable\\\\Path\\\\\"",
      "mitre": "T1574.001",
      "status": "success",
      "impact": "Payload staged and waiting for LoadLibrary API call.",
      "visibilityChanges": {
        "showNodes": [
          "malicious_dll"
        ],
        "showEdges": [
          "e_drop_dll"
        ]
      },
      "newEdges": [
        {
          "id": "e_drop_dll",
          "source": "attacker_machine",
          "target": "malicious_dll",
          "label": "Write File",
          "type": "FileDrop"
        }
      ]
    },
    {
      "id": 4,
      "title": "Trigger DLL Load",
      "description": "Restart the vulnerable service or application. The application searches the PATH, hits the attacker's DLL first, and loads it into its memory space.",
      "command": "sc stop VulnApp && sc start VulnApp",
      "mitre": "T1574.001",
      "status": "success",
      "impact": "DllMain executes payload directly within the memory boundary of the SYSTEM application.",
      "visibilityChanges": {
        "showNodes": [
          "system_shell"
        ],
