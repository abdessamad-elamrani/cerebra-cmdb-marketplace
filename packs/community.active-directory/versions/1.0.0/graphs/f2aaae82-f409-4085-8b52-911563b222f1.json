  "steps": [
    {
      "id": 1,
      "name": "Load PowerView Module",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powerview_module",
      "description": "The attacker imports the PowerView script into the current PowerShell session, making its cmdlets available.",
      "cli": "Import-Module .\\PowerView.ps1"
    },
    {
      "id": 2,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powerview_module",
      "to": "corporate_network",
      "description": "PowerView reaches the domain LDAP path used to enumerate computer objects."
    },
    {
      "id": 3,
      "name": "Initiate LDAP Query",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The Domain Controller receives the LDAP query for computer objects and operating-system metadata.",
      "cli": "Get-NetComputer | select operatingsystem, operatingsystemversion",
      "mitre": {
        "id": "T1018",
        "tactic": "Discovery",
        "technique": "Remote System Discovery"
      }
    },
    {
      "id": 4,
      "name": "Return Computer Roster",
      "type": "edge",
      "from": "domain_controller",
      "to": "computer_list",
      "description": "The Domain Controller returns the list of computer objects with OS details for targeting."
    }
  ]
