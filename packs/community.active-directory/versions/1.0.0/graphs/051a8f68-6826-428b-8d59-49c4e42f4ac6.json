    {
      "id": 1,
      "name": "Operate from Compromised Endpoint",
      "type": "edge",
      "from": "attacker_machine",
      "to": "c2_beacon",
      "description": "The attacker uses an existing foothold on the compromised endpoint to execute Rubeus in memory."
    },
    {
      "id": 2,
      "name": "Load Rubeus in Memory",
      "type": "edge",
      "from": "c2_beacon",
      "to": "rubeus_assembly",
      "description": "The attacker executes Rubeus from the compromised endpoint to begin Kerberoasting.",
      "cli": ".\\Rubeus.exe kerberoast /outfile:hashes.kerberoast"
    },
    {
      "id": 3,
      "name": "Reach Kerberos Ticket Service Path",
      "type": "edge",
      "from": "rubeus_assembly",
      "to": "corporate_network",
      "description": "Rubeus reaches the domain services needed to locate SPNs and request service tickets."
    },
    {
      "id": 4,
      "name": "Request Service Tickets for SPNs",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The Domain Controller returns crackable service-ticket material for SPN-bearing accounts.",
      "mitre": {
        "id": "T1558.003",
        "tactic": "Credential Access",
        "technique": "Steal or Forge Kerberos Tickets: Kerberoasting"
      }
    },
