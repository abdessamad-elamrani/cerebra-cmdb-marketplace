  "steps": [
    {
      "id": 1,
      "name": "Export Cached Tickets",
      "type": "edge",
      "from": "attacker_machine",
      "to": "mimikatz_tool",
      "description": "The attacker launches Mimikatz on the compromised host to work with cached Kerberos ticket material."
    },
    {
      "id": 2,
      "name": "Write .kirbi Ticket to Disk",
      "type": "edge",
      "from": "mimikatz_tool",
      "to": "kirbi_file",
      "description": "Cached tickets are exported from memory and saved as .kirbi files.",
      "cli": "sekurlsa::tickets /export",
      "mitre": {
        "id": "T1558",
        "tactic": "Credential Access",
        "technique": "Steal or Forge Kerberos Tickets"
      }
    },
    {
      "id": 3,
      "name": "Inject Selected Ticket",
      "type": "edge",
      "from": "kirbi_file",
      "to": "mimikatz_tool",
      "description": "A selected .kirbi ticket is injected into the current session for reuse.",
      "cli": "kerberos::ptt <ticket>.kirbi",
      "mitre": {
        "id": "T1550.003",
        "tactic": "Lateral Movement",
        "technique": "Use Alternate Authentication Material: Pass the Ticket"
      }
    },
    {
      "id": 4,
      "name": "Reach Kerberos Trust Boundary",
      "type": "edge",
      "from": "attacker_machine",
      "to": "corporate_network",
      "description": "The compromised host uses the injected ticket while reaching out to domain-backed services."
    },
    {
      "id": 5,
      "name": "Access Protected Resource",
      "type": "edge",
      "from": "corporate_network",
      "to": "target_resource",
      "description": "The injected ticket is accepted and the attacker gains Kerberos-backed access to the protected resource."
    }
  ],
  "attackMatrixOpen": false,
  "sizeControlsOpen": false
}
