  "steps": [
    {
      "id": 1,
      "name": "Launch CME Dump Workflow",
      "type": "edge",
      "from": "attacker_machine",
      "to": "cme_tool",
      "description": "The attacker starts CrackMapExec with the --sam action against one host or an entire subnet.",
      "cli": "crackmapexec smb 10.0.2.0/24 -u fcastle -d MARVEL.local -p Password1 --sam"
    },
    {
      "id": 2,
      "name": "Authenticate Across Target Scope",
      "type": "edge",
      "from": "cme_tool",
      "to": "corporate_network",
      "description": "CME uses SMB authentication to reach one or more remote Windows hosts where the supplied credentials have administrative value."
    },
    {
      "id": 3,
      "name": "Invoke Remote SAM Extraction",
      "mitre": {
        "id": "T1003.002",
        "tactic": "Credential Access",
        "technique": "OS Credential Dumping: Security Account Manager"
      },
      "type": "edge",
      "from": "corporate_network",
      "to": "target_windows",
      "description": "The target Windows system services the request that exposes local credential material through CME's remote dumping workflow."
    },
    {
      "id": 4,
      "name": "Return Dumped Hash Material",
      "type": "edge",
      "from": "target_windows",
      "to": "cme_tool",
      "description": "The remote credential material is returned to CrackMapExec for parsing and display."
    },
    {
      "id": 5,
      "name": "Store Local Hash Set",
      "type": "edge",
      "from": "cme_tool",
      "to": "stolen_sam_hashes",
      "description": "The attacker retains the dumped NTLM hashes for offline cracking or pass-the-hash operations."
    }
