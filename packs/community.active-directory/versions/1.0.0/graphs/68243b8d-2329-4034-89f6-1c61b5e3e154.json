  "steps": [
    {
      "id": 1,
      "name": "Operate Existing Meterpreter Session",
      "type": "edge",
      "from": "target_host",
      "to": "meterpreter_session",
      "description": "The attacker works inside an existing Meterpreter foothold on the compromised Windows host."
    },
    {
      "id": 2,
      "name": "Enumerate Available Tokens",
      "type": "edge",
      "from": "meterpreter_session",
      "to": "lsass_memory",
      "description": "The Incognito extension queries available user tokens currently accessible from the session.",
      "cli": "load incognito\nlist_tokens -u"
    },
    {
      "id": 3,
      "name": "Impersonate Selected Token",
      "type": "edge",
      "from": "lsass_memory",
      "to": "victim_token",
      "description": "A selected token is duplicated and applied so the attacker can act under that user context.",
      "cli": "impersonate_token marvel\\fcastle"
    }
  ],
  "attackMatrixOpen": false,
  "sizeControlsOpen": false
