  "steps": [
    {
      "id": 1,
      "name": "Load PowerView Module",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powerview_module",
      "description": "The attacker imports the PowerView script into the current PowerShell session so GPO enumeration cmdlets become available.",
      "cli": "Import-Module .\\PowerView.ps1"
    },
    {
      "id": 2,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powerview_module",
      "to": "corporate_network",
      "description": "PowerView reaches the domain LDAP path used to enumerate Group Policy Objects."
    },
    {
      "id": 3,
      "name": "Initiate LDAP GPO Query",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The Domain Controller is queried for groupPolicyContainer objects and associated metadata.",
      "cli": "Get-NetGPO | select displayname, whenchanged",
      "mitre": {
        "id": "T1615",
        "tactic": "Discovery",
        "technique": "Group Policy Discovery"
      }
    },
    {
      "id": 4,
      "name": "Return Policy Metadata",
      "type": "edge",
      "from": "domain_controller",
      "to": "powerview_module",
      "description": "The Domain Controller returns the matching GPO records, including names and modification timestamps."
    },
    {
      "id": 5,
      "name": "Assemble GPO Inventory",
      "type": "edge",
      "from": "powerview_module",
      "to": "gpo_list",
      "description": "The attacker reviews the returned policy inventory to identify interesting or recently changed Group Policy Objects."
    }
  ]
