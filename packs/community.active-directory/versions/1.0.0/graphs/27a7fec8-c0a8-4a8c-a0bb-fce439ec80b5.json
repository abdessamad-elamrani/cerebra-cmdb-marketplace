  "steps": [
    {
      "id": 1,
      "name": "Prepare Custom Directory Search",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powershell_process",
      "description": "The attacker uses PowerShell and .NET classes to prepare a manual LDAP search for domain user objects."
    },
    {
      "id": 2,
      "name": "Create Directory Entry and Searcher",
      "type": "edge",
      "from": "powershell_process",
      "to": "ad_properties",
      "description": "PowerShell creates the local search context used for a custom LDAP query.",
      "cli": "$direntry = New-Object System.DirectoryServices.DirectoryEntry($LDAP)\n$dirsearcher = New-Object System.DirectoryServices.DirectorySearcher($direntry)"
    },
    {
      "id": 3,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powershell_process",
      "to": "corporate_network",
      "description": "The custom DirectorySearcher reaches the corporate network path used for LDAP access."
    },
    {
      "id": 4,
      "name": "Submit LDAP User Query",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "A custom LDAP filter requests standard user objects from the Domain Controller.",
      "cli": "$dirsearcher.filter=\"samAccountType=805306368\"\n$result = $dirsearcher.FindAll()"
    },
    {
      "id": 5,
      "name": "Return User Property Set",
      "type": "edge",
      "from": "domain_controller",
      "to": "ad_properties",
      "description": "The directory returns the matching user objects and their readable LDAP properties for local parsing."
    }
  ],
  "visibility": {
    "ad_properties": {
      "start": 5,
