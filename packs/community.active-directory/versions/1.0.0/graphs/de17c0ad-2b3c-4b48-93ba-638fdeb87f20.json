      },
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The KDC returns AS-REP material for misconfigured users with preauthentication disabled."
    },
    {
      "id": 4,
      "name": "Save AS-REP Hashes",
      "type": "edge",
      "from": "domain_controller",
      "to": "asrep_hashes",
      "description": "The roastable Kerberos material is saved locally in a format suitable for Hashcat."
    },
    {
      "id": 5,
      "name": "Crack Recovered Material",
      "type": "edge",
      "from": "asrep_hashes",
      "to": "cracked_passwords",
      "description": "Hashcat attacks the captured AS-REP material to recover plaintext passwords.",
      "cli": "hashcat -m 18200 attractive-kerb-hash.txt /usr/share/wordlists/rockyou.txt --force"
    }
