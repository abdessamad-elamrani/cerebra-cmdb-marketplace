  "steps": [
    {
      "id": 1,
      "name": "Load PowerView Module",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powerview_tool",
      "description": "The attacker imports PowerView into the current PowerShell session for targeted SPN discovery.",
      "cli": "Import-Module .\\PowerView.ps1"
    },
    {
      "id": 2,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powerview_tool",
      "to": "corporate_network",
      "description": "The targeted SPN query reaches the domain service path for LDAP-backed account discovery."
    },
    {
      "id": 3,
      "name": "Query SPN-Bearing User Accounts",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "A targeted LDAP filter requests user objects that have populated servicePrincipalName attributes.",
      "cli": "Get-NetUser -SPN | select samaccountname,serviceprincipalname"
    },
    {
      "id": 4,
      "name": "Return Service Account Pipeline",
      "type": "edge",
      "from": "domain_controller",
      "to": "spn_objects",
      "description": "The Domain Controller returns the filtered set of SPN-bearing user objects for attacker review."
    }
