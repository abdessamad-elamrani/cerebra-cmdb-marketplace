      "id": 1,
      "name": "Start Targeted Group Lookup",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powershell_process",
      "description": "The attacker uses PowerShell and .NET LDAP classes to resolve a single user's group memberships."
    },
    {
      "id": 2,
      "name": "Create Directory Search Context",
      "type": "edge",
      "from": "powershell_process",
      "to": "memberof_array",
      "description": "PowerShell prepares the local search context used for a targeted LDAP lookup."
    },
    {
      "id": 3,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powershell_process",
      "to": "corporate_network",
      "description": "The custom DirectorySearcher reaches the domain's LDAP service path."
    },
    {
      "id": 4,
      "name": "Query Specific User Object",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "An LDAP filter requests the AD object for the chosen user account.",
      "cli": "$dirsearcher.filter=\"name=jeffadmin\"\n$result = $dirsearcher.FindAll()"
    },
    {
      "id": 5,
      "name": "Return Group Membership Array",
      "type": "edge",
      "from": "domain_controller",
      "to": "memberof_array",
      "description": "The directory returns the target user object and its memberOf attributes for local review."
    }
