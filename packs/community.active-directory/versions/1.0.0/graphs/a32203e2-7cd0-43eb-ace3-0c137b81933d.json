  "steps": [
    {
      "id": 1,
      "name": "Load PowerView Module",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powerview_script",
      "description": "The attacker operates in a PowerView-capable PowerShell session before issuing the remote session query."
    },
    {
      "id": 2,
      "name": "Reach Target Network Segment",
      "type": "edge",
      "from": "powerview_script",
      "to": "corporate_network",
      "description": "The session-enumeration request reaches the corporate network path that contains the target host."
    },
    {
      "id": 3,
      "name": "Query Remote Session Data",
      "type": "edge",
      "from": "corporate_network",
      "to": "target_machine",
      "description": "A remote session enumeration request asks the target machine which user sessions are currently exposed.",
      "cli": "Get-NetSession -ComputerName COMPUTERNAME -Verbose"
    },
    {
      "id": 4,
      "name": "Return Active Session List",
      "type": "edge",
      "from": "target_machine",
      "to": "active_sessions",
      "description": "The remote host returns its active session information to help the attacker identify useful user presence."
    }
  ],
  "visibility": {
    "active_sessions": {
      "start": 4,
