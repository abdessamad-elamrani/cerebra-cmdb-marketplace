    {
      "id": 1,
      "name": "Load PowerView Module",
      "type": "edge",
      "from": "attacker_machine",
      "to": "powerview_tool",
      "description": "The attacker imports PowerView into the current PowerShell session to enable AD reconnaissance cmdlets.",
      "cli": "Import-Module .\\PowerView.ps1"
    },
    {
      "id": 2,
      "name": "Reach Corporate LDAP Services",
      "type": "edge",
      "from": "powerview_tool",
      "to": "corporate_network",
      "description": "The PowerView module reaches the domain's LDAP service path for broad object discovery."
    },
    {
      "id": 3,
      "name": "Query Core AD Object Sets",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "Domain, user, group, and computer objects are requested through PowerView's LDAP-backed queries.",
      "cli": "Get-NetDomain\nGet-NetUser | select cn,pwdlastset,lastlogon\nGet-NetGroup | select cn\nGet-NetGroup \"Sales Department\" | select member\nGet-NetComputer"
    },
    {
      "id": 4,
      "name": "Return Broad AD Recon Output",
      "type": "edge",
      "from": "domain_controller",
      "to": "ad_data",
      "description": "The Domain Controller returns the requested object data so the attacker can build a baseline recon snapshot."
    }
