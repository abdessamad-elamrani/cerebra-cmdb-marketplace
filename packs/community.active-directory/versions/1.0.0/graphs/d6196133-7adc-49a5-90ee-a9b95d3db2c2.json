  "steps": [
    {
      "id": 1,
      "name": "Launch Share Discovery Workflow",
      "type": "edge",
      "from": "attacker_machine",
      "to": "sharefinder_tool",
      "description": "The attacker starts PowerView share discovery from the compromised endpoint.",
      "cli": "Find-DomainShare\nInvoke-ShareFinder -Verbose -CheckShareAccess"
    },
    {
      "id": 2,
      "name": "Reach Corporate Directory Services",
      "type": "edge",
      "from": "sharefinder_tool",
      "to": "corporate_network",
      "description": "The share-discovery workflow reaches the domain environment to identify remote computers worth probing."
    },
    {
      "id": 3,
      "name": "Map Candidate Computers",
      "type": "edge",
      "from": "corporate_network",
      "to": "domain_controller",
      "description": "The Domain Controller provides computer targets used for the subsequent SMB sweep."
    },
    {
      "id": 4,
      "name": "Test Readable Shares on Endpoints",
      "type": "edge",
      "from": "sharefinder_tool",
      "to": "target_endpoints",
      "description": "Remote SMB shares are probed and the current user's read access is validated.",
      "cli": "Invoke-ShareFinder -Verbose -CheckShareAccess"
    },
    {
      "id": 5,
      "name": "Return Accessible UNC Paths",
      "type": "edge",
      "from": "target_endpoints",
      "to": "readable_shares",
      "description": "The attacker receives the set of UNC paths that are immediately readable and worth browsing."
    }
  ],
